# Apple Music API 用の認証情報
#
# このアプリは2種類のトークンを扱う:
#
# 1) Developer Token (サーバー側 JWT 署名)
#    Vercel Function (api/apple.js) で ES256 署名したJWTを生成。
#    カタログ検索・曲取得と、MusicKit JS の初期化に使う。
#    キーは絶対にクライアントに露出させないこと。
#
# 2) Music User Token (クライアント側 MusicKit JS)
#    プレイリスト作成用。ユーザーが Apple Music にサインインすると発行される。
#    Juke 側でコードを書かなくても MusicKit JS が管理する。
#
# セットアップ:
# 1. Apple Developer Program に加入 ($99/year)
# 2. https://developer.apple.com/account/resources/identifiers
#    で "MusicKit Identifier" を作成
# 3. https://developer.apple.com/account/resources/authkeys
#    で "MusicKit" 用の Key を作成し、.p8 ファイルをダウンロード
#    (一度しかダウンロードできないので保管注意)
# 4. Team ID (右上の名前付近) と Key ID をメモ
# 5. このファイルを .env にコピーして値を記入
# 6. Vercel Environment Variables にも同じ変数を追加

APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX

# .p8ファイルの中身全体を貼る。改行は \n エスケープ or そのまま改行どちらでもOK。
# -----BEGIN PRIVATE KEY-----
# MIGTAg...
# -----END PRIVATE KEY-----
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
