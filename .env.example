# Juke は Spotify と Apple Music の両方に対応しています。
# どちらか片方だけでも動作しますが、両方のユーザーに並び順再生を提供するなら両方設定してください。
#
# -----------------------------------------------------------
# Spotify (検索・曲取得・プレイリスト作成)
# -----------------------------------------------------------
# 1. https://developer.spotify.com/dashboard でアプリを作成
# 2. Client ID / Client Secret を取得
# 3. Redirect URIs に以下を登録:
#       http://127.0.0.1:5173/callback
#       https://<your-vercel-domain>/callback

# サーバー側: Client Credentialsフロー (検索・曲取得代行)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# クライアント側: PKCEフロー (プレイリスト作成)
VITE_SPOTIFY_CLIENT_ID=

# -----------------------------------------------------------
# Apple Music (プレイリスト作成のみ。検索はSpotifyを使用)
# -----------------------------------------------------------
# 1. Apple Developer Program に加入 ($99/year)
# 2. https://developer.apple.com/account/resources/identifiers
#    で Media IDs → Music を作成
# 3. https://developer.apple.com/account/resources/authkeys
#    で MusicKit を有効にしたKeyを作成、.p8 をダウンロード
# 4. Team ID (右上) と Key ID をメモ
# APPLE_* 系が未設定の場合、モーダルで Apple Music 選択肢は表示されますが
# 選ぶと "Developer Token 未設定" でエラーになります。

APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
