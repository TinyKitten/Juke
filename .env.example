# Spotify Web API — Authorization Code + PKCE
#
# Setup:
# 1. Go to https://developer.spotify.com/dashboard and create an app.
# 2. In the app settings, add this as a Redirect URI:
#       http://127.0.0.1:5173/callback
#    (Spotify no longer accepts "localhost"; use 127.0.0.1.)
# 3. Copy your Client ID here and rename this file to `.env`.
# 4. Restart `npm run dev`.
#
# If VITE_SPOTIFY_CLIENT_ID is unset, the app falls back to a mock
# Spotify backend (the Tweaks panel's `SPOTIFY ACCOUNT` switch controls
# premium/free in that mode).

VITE_SPOTIFY_CLIENT_ID=
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/callback
